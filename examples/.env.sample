# Copy this file to examples/.env and fill in local values.

# Required for OpenAI model calls.
OPENAI_API_KEY=

# Optional. Lesson 05 can use Claude by changing AI_ARCHITECT_MODEL.
ANTHROPIC_API_KEY=
AI_ARCHITECT_MODEL=openai:gpt-5.6

# Required for the Lesson 07 Postgres and pgvector examples.
DATABASE_URL=postgresql://localhost/ai_architect
